'use client'

import { useState, useEffect } from 'react'
import { JobCardSkeleton } from '@/components/Loading'
import { supabase } from '@/lib/supabase'

const US_STATES = ['All States', 'PA', 'NJ', 'DE', 'NY', 'CT', 'MD', 'VA', 'FL', 'NC', 'OH', 'MA']
const TRADES = ['All Trades', 'Interior Painting', 'Exterior Painting', 'Cabinet Painting', 'Drywall Repair', 'Power Washing', 'Staining']

function StarDisplay({ rating }: { rating: number }) {
  const r = Math.round(rating * 10) / 10
  return (
    <span className="flex items-center gap-0.5 text-sm font-medium">
      {[1,2,3,4,5].map(s => (
        <svg key={s} className={`w-4 h-4 ${s <= Math.round(r) ? 'text-yellow-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      ))}
      <span className="text-gray-400 ml-1">{r}/5</span>
    </span>
  )
}

export default function Jobs() {
  const [jobs, setJobs] = useState<any[]>([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState('')
  const [expressingId, setExpressingId] = useState<string | null>(null)
  const [expressedJobs, setExpressedJobs] = useState<Set<string>>(new Set())
  const [stateFilter, setStateFilter] = useState('All States')
  const [tradeFilter, setTradeFilter] = useState('All Trades')
  const [contractorRatings, setContractorRatings] = useState<Record<string, number>>({})
  const [networkRating, setNetworkRating] = useState<number | null>(null)

  useEffect(() => {
    Promise.all([
      fetch('/api/jobs').then(r => r.json()),
      fetch('/api/reviews').then(r => r.json()),
    ]).then(([jobsData, reviewsData]) => {
      setJobs(jobsData || [])
      if (reviewsData?.averages) {
        setContractorRatings(reviewsData.averages)
        // Compute network-wide average rating
        const vals = Object.values(reviewsData.averages) as number[]
        if (vals.length > 0) {
          const avg = vals.reduce((a, b) => a + b, 0) / vals.length
          setNetworkRating(Math.round(avg * 10) / 10)
        }
      }
      setLoading(false)
    }).catch(() => {
      setError('Failed to load jobs. Please try again.')
      setLoading(false)
    })
  }, [])

  const handleExpressInterest = async (jobId: string) => {
    setExpressingId(jobId)
    setError('')
    try {
      // Get contractor_id from Supabase Auth session — null if not authenticated
      const { data: { session } } = await supabase.auth.getSession()
      const contractorId = session?.user?.user_metadata?.contractor_id ?? null

      const res = await fetch(`/api/jobs/${jobId}/interest`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contractor_id: contractorId }),
      })

      if (res.ok) {
        setExpressedJobs(prev => new Set([...prev, jobId]))
      } else {
        setError('Failed to express interest. Please try again.')
      }
    } catch {
      setError('Network error. Please check your connection and try again.')
    } finally {
      setExpressingId(null)
    }
  }

  const filteredJobs = jobs.filter(job => {
    const stateMatch = stateFilter === 'All States' || (job.area || '').includes(stateFilter)
    const tradeMatch = tradeFilter === 'All Trades' || (job.scope || '').toLowerCase().includes(tradeFilter.toLowerCase())
    return stateMatch && tradeMatch
  })

  return (
    <div className="min-h-screen bg-gray-50">
      <header className="bg-white border-b py-4 px-6">
        <div className="max-w-4xl mx-auto flex justify-between items-center">
          <div className="flex items-center gap-4">
            <h1 className="text-xl font-bold text-[#1e3a5f]">Available Jobs</h1>
            {networkRating && (
              <div className="flex items-center gap-1.5 bg-yellow-50 border border-yellow-200 px-3 py-1 rounded-full">
                <svg className="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span className="text-yellow-700 font-bold text-sm">{networkRating}/5</span>
                <span className="text-yellow-600 text-xs">Contractor Rating</span>
              </div>
                <span className="text-yellow-700 text-xs">Contractor Rating</span>
              </div>
            )}
          </div>
          <a href="/" className="text-sm text-gray-600 hover:text-gray-900">Home</a>
        </div>
      </header>

      {/* Filters */}
      <div className="max-w-4xl mx-auto p-6 pb-0">
        <div className="flex gap-3 flex-wrap">
          <select
            value={stateFilter}
            onChange={e => setStateFilter(e.target.value)}
            className="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white"
          >
            {US_STATES.map(s => <option key={s} value={s}>{s}</option>)}
          </select>
          <select
            value={tradeFilter}
            onChange={e => setTradeFilter(e.target.value)}
            className="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white"
          >
            {TRADES.map(t => <option key={t} value={t}>{t}</option>)}
          </select>
          {(stateFilter !== 'All States' || tradeFilter !== 'All Trades') && (
            <button
              onClick={() => { setStateFilter('All States'); setTradeFilter('All Trades') }}
              className="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-500 hover:text-gray-700"
            >
              Clear Filters
            </button>
          )}
        </div>
      </div>

      <div className="max-w-4xl mx-auto p-6">
        {loading ? (
          <div className="space-y-4">
            {[1, 2, 3].map(i => <JobCardSkeleton key={i} />)}
          </div>
        ) : error ? (
          <div className="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">
            {error}
          </div>
        ) : filteredJobs.length === 0 ? (
          <p className="text-gray-500">No jobs match your filters</p>
        ) : (
          <div className="space-y-4">
            {filteredJobs.map(job => (
              <div key={job.id} className="bg-white rounded-xl shadow-sm p-6">
                {error && expressingId === job.id && (
                  <div className="bg-red-50 border border-red-200 text-red-700 px-3 py-2 rounded-lg mb-3 text-sm">
                    {error}
                  </div>
                )}
                <div className="flex justify-between items-start mb-3">
                  <div className="flex items-center gap-2 flex-wrap">
                    <h3 className="font-bold text-lg">{job.title}</h3>
                    {job.is_verified_homeowner ? (
                      <span className="px-2 py-0.5 bg-green-100 text-green-700 rounded-full text-xs font-medium flex items-center gap-1">
                        <svg className="w-3 h-3 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}>
                          <path strokeLinecap="round" strokeLinejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                        Verified Homeowner
                      </span>
                    ) : (
                      <span className="px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full text-xs flex items-center gap-1">
                        <svg className="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                          <path strokeLinecap="round" strokeLinejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        Guest Posting
                      </span>
                    )}
                    {job.contractor_id && contractorRatings[job.contractor_id] && (
                      <span className="px-2 py-0.5 bg-yellow-50 border border-yellow-200 text-yellow-700 rounded-full text-xs flex items-center gap-1">
                        <svg className="w-3 h-3 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {contractorRatings[job.contractor_id]}/5 Contractor
                      </span>
                    )}
                  </div>
                  <span className="px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm">
                    {job.status}
                  </span>
                </div>
                <p className="text-gray-600 mb-4">{job.description}</p>
                <div className="flex justify-between items-center text-sm">
                  <div className="text-gray-500">
                    <span>{job.area || 'Location TBD'}</span>
                    {job.scope && <span className="mx-2">•</span>}
                    {job.scope && <span className="text-[#1e3a5f] font-medium">{job.scope}</span>}
                  </div>
                  <button
                    onClick={() => handleExpressInterest(job.id)}
                    disabled={expressingId === job.id || expressedJobs.has(job.id)}
                    className={`px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2 ${
                      expressedJobs.has(job.id)
                        ? 'bg-green-100 text-green-800 cursor-default'
                        : expressingId === job.id
                        ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
                        : 'bg-[#1e3a5f] text-white hover:bg-[#2a5296]'
                    }`}
                  >
                    {expressedJobs.has(job.id) ? (
                      <>
                        <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7" /></svg>
                        Interest Expressed
                      </>
                    ) : expressingId === job.id ? (
                      <>
                        <span className="inline-block w-4 h-4 border-2 border-gray-400 border-t-transparent rounded-full animate-spin" />
                        Processing...
                      </>
                    ) : (
                      'Express Interest'
                    )}
                  </button>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
